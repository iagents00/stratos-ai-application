# Stratos AI — Variables de entorno
# Copia este archivo como .env.local y llena los valores reales.
# NUNCA subas .env.local a Git.

# URL del subdominio de la aplicación (donde vive el CRM, ERP, etc.)
VITE_APP_URL=https://app.stratoscapitalgroup.com

# Supabase (cuando migres de localStorage a BD real)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
